# 必填：本地或线上 MySQL 连接串
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://root:your_password@localhost:3306/job_application_manager"

# 说明：
# 1. 数据库需要提前创建
# 2. 当前项目启动与 Prisma 命令都依赖这个变量
# 3. 修改后请重启本地开发服务
#
# Railway MySQL 示例：
# DATABASE_URL="mysql://root:your_password@your-tcp-proxy-host.railway.app:12345/railway"
#
# 注意：
# - Vercel 连接 Railway 时，请使用 Railway 提供的外部连接串 / TCP Proxy 地址
# - 不要把 *.railway.internal 这类内网地址直接填给 Vercel
