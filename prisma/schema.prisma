generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ApplicationStatus {
  BOOKMARKED
  TODO_APPLY
  APPLIED
  WRITTEN_TEST
  INTERVIEWING
  OFFER
  CLOSED
}

enum Priority {
  low
  medium
  high
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  jobTitle      String
  status        ApplicationStatus     @default(TODO_APPLY)
  priority      Priority              @default(medium)
  city          String?
  source        String?
  sourceUrl     String?
  salaryRange   String?
  notes         String?               @db.Text
  appliedAt     DateTime?
  deadlineAt    DateTime?
  nextAction    String?
  nextActionAt  DateTime?
  stageLogs     ApplicationStageLog[]
  interviews    Interview[]
  reminders     Reminder[]
  attachments   Attachment[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([companyName])
}

model ApplicationStageLog {
  id             String            @id @default(cuid())
  applicationId  String
  application    Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus     ApplicationStatus?
  toStatus       ApplicationStatus
  note           String?           @db.Text
  changedAt      DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([applicationId])
  @@index([changedAt])
}

model Interview {
  id             String       @id @default(cuid())
  applicationId  String
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  round          Int          @default(1)
  title          String
  interviewType  String?
  scheduledAt    DateTime
  location       String?
  meetingUrl     String?
  interviewer    String?
  result         String?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([applicationId])
  @@index([scheduledAt])
}

model Reminder {
  id             String       @id @default(cuid())
  applicationId  String
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title          String
  remindAt       DateTime
  isCompleted    Boolean      @default(false)
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([applicationId])
  @@index([remindAt])
  @@index([isCompleted])
}

model Attachment {
  id             String       @id @default(cuid())
  applicationId  String
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fileName       String
  fileType       String?
  fileUrl        String
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([applicationId])
}
